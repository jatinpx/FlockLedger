# DATABASE_URL — pick one:
# - Neon: full URL from dashboard (include sslmode=require if shown)
# - Docker Compose + bundled Postgres (backend container): postgresql://flock:flock@postgres:5432/flockledger
# - Same Postgres from Windows/WSL host (compose maps host 5433 → container 5432):
#   postgresql://flock:flock@localhost:5433/flockledger
# - Native Postgres on default port: postgresql://flock:flock@localhost:5432/flockledger
DATABASE_URL=postgresql://flock:flock@postgres:5432/flockledger

# For uvicorn on your machine (not Docker). In Compose, redis://redis:6379/0 is injected for you.
REDIS_URL=redis://localhost:6379/0

# 1 = run `alembic upgrade head` when the API process starts (default). Set 0 if you
# migrate separately or use multiple uvicorn workers (migrate once, then start workers).
RUN_MIGRATIONS_ON_STARTUP=1
SECRET_KEY=change-me
BACKEND_CORS_ORIGINS=http://localhost:3000
